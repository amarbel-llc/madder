# vim: ft=toml

[hooks]
pre-merge = "just"

# Per-commit repair: format the index-staged content at authoring time so every
# commit is conformant in history. Uses `conformist-pre-commit` — the
# config-specific, toolchain-hermetic wrapper the conformist Nix module exposes
# (conformistEval.config.build.preCommit, put on the devShell PATH via flake.nix
# + go/default.nix). It BAKES this repo's generated store-path config (madder
# has no on-disk conformist.toml — the config moved to ./conformist.nix) and
# store-pins the formatter toolchain, with `--exit-zero-on-fix` baked in. So
# per-commit repair can't fail on a missing config (the bare `conformist
# --staged` errored "could not find config file" here) and can't silently skip
# a file type whose formatter isn't on PATH (conformist#47/#51; the eng template
# warns "Do NOT use a bare conformist --staged"). The `pre-merge = "just"`
# lint-fmt gate stays as the loud backstop. Requires the devShell active
# (direnv) so `conformist-pre-commit` is on PATH.
pre-commit = "conformist-pre-commit"
