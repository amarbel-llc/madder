bats_timeout := "30"

default: test

# Run all bats test files.
[group("test")]
test-targets *targets="*.bats":
  BATS_TEST_TIMEOUT="{{bats_timeout}}" \
    bats --jobs {{num_cpus()}} {{targets}}

# Run bats tests filtered by tag.
[group("test")]
test-tags *tags:
  BATS_TEST_TIMEOUT="{{bats_timeout}}" \
    bats --jobs {{num_cpus()}} --filter-tags {{tags}} *.bats

# Run the default integration test suite. Excludes net_cap-tagged
# tests (loopback-binding scenarios) — those run under `test-net-cap`
# with sandcastle's --allow-local-binding granted.
[group("test")]
test:
  BATS_TEST_TIMEOUT="{{bats_timeout}}" \
    bats --jobs {{num_cpus()}} --filter-tags '!net_cap' *.bats

# Run net_cap-tagged tests (SFTP + WebDAV harnesses) in the devshell
# for fast iteration. The authoritative CI path runs them via
# `nix build .#bats-net_cap` (see top-level justfile's
# `test-bats-net-cap`); this recipe is the same suite invoked
# directly against $PWD's binaries so devs can iterate without
# rebuilding the lane.
#
# TMPDIR=/tmp pins the per-test tmpdir to a short prefix. macOS's
# default $TMPDIR is a long per-user path, and our session $TMPDIR is
# worktree-rooted — either overruns the ~104-char Unix-domain
# sun_path limit once bats appends bats-run-XXX/test/NN/home/.ssh/
# agent/s.<rand>.agent.<rand>, breaking the ssh-agent harness used
# by sftp_analyze_and_suggest_configs.bats.
[group("test")]
test-net-cap:
  TMPDIR=/tmp BATS_TEST_TIMEOUT="{{bats_timeout}}" \
    bats --jobs {{num_cpus()}} --filter-tags net_cap *.bats
